<Window x:Class="DailyWords.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="悬浮置顶单词本"
        Width="380"
        Height="250"
        MinWidth="380"
        MaxWidth="380"
        MinHeight="250"
        MaxHeight="250"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        LocationChanged="Window_LocationChanged">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <Style x:Key="ActionButtonStyle" TargetType="Button">
      <Setter Property="Margin" Value="4,0,4,0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Background" Value="#EEF4EA" />
      <Setter Property="BorderBrush" Value="#D7E4D2" />
      <Setter Property="Foreground" Value="#26422D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
  </Window.Resources>

  <Border x:Name="WordCardBorder"
          Padding="16"
          CornerRadius="18"
          Background="#F9FCF8"
          BorderBrush="#D8E7D1"
          BorderThickness="1"
          MouseLeftButtonDown="WordCardBorder_MouseLeftButtonDown">
    <Border.Effect>
      <DropShadowEffect BlurRadius="20"
                        ShadowDepth="0"
                        Opacity="0.22"
                        Color="#55000000" />
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0"
                 FontFamily="Microsoft YaHei UI"
                 FontSize="28"
                 FontWeight="SemiBold"
                 Foreground="#183E26"
                 Text="{Binding CurrentWordText}" />

      <TextBlock Grid.Row="1"
                 Margin="0,4,0,0"
                 Foreground="#53705C"
                 FontSize="13"
                 Text="{Binding CurrentPhonetic}"
                 Visibility="{Binding CanShowPhonetic, Converter={StaticResource BoolToVisibilityConverter}}" />

      <TextBlock Grid.Row="2"
                 Margin="0,10,0,0"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="#284B33"
                 TextWrapping="Wrap"
                 Text="{Binding CurrentMeaning}"
                 Visibility="{Binding CanShowMeaning, Converter={StaticResource BoolToVisibilityConverter}}" />

      <Border Grid.Row="3"
              Margin="0,12,0,0"
              Padding="10"
              Background="#F1F6EE"
              CornerRadius="12"
              Visibility="{Binding CanShowExample, Converter={StaticResource BoolToVisibilityConverter}}">
        <TextBlock FontSize="12"
                   Foreground="#4B6154"
                   TextWrapping="Wrap"
                   Text="{Binding CurrentExample}" />
      </Border>

      <Grid Grid.Row="4"
            Margin="0,12,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Foreground="#42574A"
                     FontSize="12"
                     Text="{Binding StatusText}" />
          <TextBlock Margin="0,2,0,0"
                     Foreground="#6B7E70"
                     FontSize="11"
                     Text="{Binding SecondaryStatusText}" />
        </StackPanel>
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Foreground="#68806D"
                   FontSize="11"
                   Text="{Binding WindowTipText}" />
      </Grid>

      <UniformGrid Grid.Row="5"
                   Columns="5">
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="PreviousButton_Click"
                Content="上一个" />
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="PlayButton_Click"
                Content="{Binding PlaybackButtonText}" />
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="NextButton_Click"
                Content="下一个" />
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="MasteredButton_Click"
                IsEnabled="{Binding CanToggleMastered}"
                Content="{Binding MarkButtonText}" />
        <Button Style="{StaticResource ActionButtonStyle}"
                Click="SettingsButton_Click"
                Content="设置" />
      </UniformGrid>
    </Grid>
  </Border>
</Window>
